{
  "id": "battlecard",
  "title": "Battlecard",
  "description": "A single two-phase attack dialog and one evolving chat card per attack sequence for dnd5e. Automates choreography, never rules — hit/miss adjudication stays human.",
  "version": "0.1.0",
  "authors": [
    {
      "name": "gginns"
    }
  ],
  "url": "https://github.com/gginns/battlecard",
  "manifest": "https://github.com/gginns/battlecard/releases/latest/download/module.json",
  "download": "https://github.com/gginns/battlecard/releases/download/v0.1.0/battlecard.zip",
  "compatibility": {
    "minimum": "13",
    "verified": "14"
  },
  "relationships": {
    "systems": [
      {
        "id": "dnd5e",
        "type": "system",
        "compatibility": {
          "minimum": "4.1.0",
          "verified": "5.3.2"
        }
      }
    ]
  },
  "esmodules": [
    "scripts/main.js"
  ],
  "styles": [
    "styles/module.css"
  ],
  "languages": [
    {
      "lang": "en",
      "name": "English",
      "path": "lang/en.json"
    }
  ],
  "socket": true,
  "flags": {
    "hotReload": {
      "extensions": ["css", "hbs", "json"],
      "paths": ["styles", "templates", "lang"]
    }
  }
}
